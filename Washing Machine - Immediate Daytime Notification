alias: Washing Machine - Immediate Daytime Notification
description: Notifies immediately if the Miele finishes between 07:00 and 23:59
triggers:
  - trigger: state
    entity_id: sensor.washing_machine
    to: program_ended
conditions:
  - condition: time
    after: "07:00:00"
    before: "23:59:59"
actions:
  - action: notify.mobile_app_hannahs_iphone
    data:
      title: 🫧 Washing Done!
      message: The Miele has finished — time to hang it out.
      data:
        push:
          interruption-level: time-sensitive
  - action: notify.mobile_app_padg_neo
    data:
      title: 🫧 Washing Done!
      message: The Miele has finished — time to hang it out.
      data:
        persistent: true
        sticky: true
        tag: washing_machine_done
        notification_icon: mdi:washing-machine
  - action: input_boolean.turn_off
    target:
      entity_id: input_boolean.washing_machine_cycle_complete
mode: single
