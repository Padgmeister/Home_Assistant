alias: Washing Machine - Flag Cycle Complete
description: Sets a flag when the Miele program_ended state is detected, any time of day
triggers:
  - trigger: state
    entity_id: sensor.washing_machine
    to: program_ended
conditions: []
actions:
  - action: input_boolean.turn_on
    target:
      entity_id: input_boolean.washing_machine_cycle_complete
mode: single
